# ============================================
# Franco (refranco.ai) — Variables de Entorno
# ============================================
# Copiar este archivo como .env.local y completar los valores
# Todas las variables son OBLIGATORIAS salvo las marcadas como (opcional)

# --- SUPABASE ---
# Dashboard: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- SITIO ---
# URL base del sitio en producción
NEXT_PUBLIC_SITE_URL=https://refranco.ai

# --- GOOGLE MAPS ---
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# La key pública es para Autocomplete en el browser (restringida por HTTP referrer)
# La key server es para geocodificación server-side
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_MAPS_API_KEY=AIza...

# --- PAGOS (FLOW.CL) ---
# Dashboard: https://www.flow.cl → Configuración → API
FLOW_API_KEY=tu_flow_api_key
FLOW_SECRET_KEY=tu_flow_secret_key

# --- EMAIL (RESEND) ---
# Dashboard: https://resend.com → API Keys
# Dominio verificado: refranco.ai
RESEND_API_KEY=re_...

# --- ANALYTICS (POSTHOG) ---
# Dashboard: https://us.posthog.com → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- ERROR TRACKING (SENTRY) ---
# Dashboard: https://sentry.io → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.us.sentry.io/...

# --- SEGURIDAD ---
# Secret para proteger endpoints de cron jobs y admin
# Generar con: openssl rand -base64 32
CRON_SECRET=tu_cron_secret_largo

# Email del administrador (para proteger /admin)
ADMIN_EMAIL=tu@email.com

# --- BANCO CENTRAL DE CHILE ---
# API para UF y tasa hipotecaria
# Registro: https://si3.bcentral.cl/Siete/es/Siete/API
BCCH_API_USER=tu_email
BCCH_API_PASS=tu_password

# --- FIRECRAWL (opcional) ---
# Solo si usas el scraper via Firecrawl
# Dashboard: https://firecrawl.dev
FIRECRAWL_API_KEY=fc_...
